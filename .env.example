# Supabase — copy from your project's API settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# The URL Supabase will redirect to after OAuth sign-in.
# In development: http://localhost:3100
# In production: https://your-app.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3100

# OpenAI — for the public job description analyzer
OPENAI_API_KEY=your-openai-api-key-here
