# Supabase — copy from your project's API settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role — server-only (cron job monitor). NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# The URL Supabase will redirect to after OAuth sign-in.
# In development: http://localhost:3100
# In production: https://your-app.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3100

# OpenAI — for the job description analyzer and monitor extraction
OPENAI_API_KEY=your-openai-api-key-here

# Job Monitor — Firecrawl scrapes careers pages; Resend sends daily digests
FIRECRAWL_API_KEY=your-firecrawl-api-key-here
RESEND_API_KEY=your-resend-api-key-here
MONITOR_EMAIL_FROM=onboarding@resend.dev

# Vercel Cron — set in Vercel project env; Vercel sends Authorization: Bearer <secret>
CRON_SECRET=generate-a-long-random-string
